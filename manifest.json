{
  "manifest_version": 3,
  "name": "TagWrap",
  "short_name": "TagWrap",
  "version": "1.0.0",
  "description": "Right-click to instantly wrap selected text with custom XML tags directly in the page. Configure your tags via the extension popup.",
  "author": "OMinus",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "XMLWrap Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": []
}
